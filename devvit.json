{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "queue-sentinel",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "app.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Open Queue Sentinel",
        "description": "Create a Queue Sentinel workbench post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  }
}
