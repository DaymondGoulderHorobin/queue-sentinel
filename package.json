{
  "private": true,
  "name": "queue-sentinel",
  "version": "0.0.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "npm run type-check && npm run lint && npm run test",
    "deploy": "npm run check && devvit upload",
    "dev": "devvit playtest",
    "dev:shell": "vite --host 127.0.0.1 --config vite.shell.config.ts",
    "launch": "npm run deploy && devvit publish",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "login": "devvit login",
    "prettier": "prettier --write .",
    "test": "vitest run --config vitest.config.ts",
    "type-check": "tsc --build"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/start": "0.12.23",
    "@devvit/web": "0.12.23",
    "@hono/node-server": "2.0.2",
    "devvit": "0.12.23",
    "hono": "4.12.18",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "^22.19.7",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "17.2.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vite": "8.0.12",
    "vitest": "4.1.6"
  }
}
