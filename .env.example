# Queue Sentinel Sprint 4 has no required secrets.
# Read-only playtest ingestion is disabled unless all guard flags are set.

# Example only:
# QUEUE_SENTINEL_DEMO_MODE=true

# Optional local override:
# QUEUE_SENTINEL_STORE_MODE=memory

# Optional private playtest ingestion guardrails:
# QUEUE_SENTINEL_ENABLE_READONLY_INGESTION=true
# QUEUE_SENTINEL_INGESTION_MODE=playtest-readonly
# QUEUE_SENTINEL_TEST_SUBREDDIT=queue_sentinel_lab
# QUEUE_SENTINEL_ALLOWED_SUBREDDITS=queue_sentinel_lab
